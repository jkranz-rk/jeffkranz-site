---
import { gear } from '../data/gear';

const guitars = gear.filter(g => g.category === 'Guitar');
const amps = gear.filter(g => g.category === 'Amplifier');
const pedals = gear.filter(g => g.category === 'Pedal');
---

<section id="guitar">
  <div class="container">
    <p class="section-label">Hobby</p>
    <h2 class="section-title">Guitar</h2>
    <div class="divider"></div>
    <p class="section-intro">
      Guitar is where I've spent most of my musical life. I'm drawn to the physical craft of playing as much as the sound — the feel of the neck, the response of the amp, the way a chain of effects can transform a single note. The gear below is what I reach for.
    </p>

    <div class="gear-group">
      <h3 class="group-title">Guitars</h3>
      <div class="gear-grid">
        {guitars.map(item => (
          <div class="gear-card">
            <div class="gear-img-wrap">
              <img src={item.image} alt={item.name} />
            </div>
            <div class="gear-body">
              <span class="gear-cat">{item.category}</span>
              <h4 class="gear-name">{item.name}</h4>
              <p class="gear-note">{item.note}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="gear-group">
      <h3 class="group-title">Amplifier</h3>
      <div class="gear-grid gear-grid--amp">
        {amps.map(item => (
          <div class="gear-card gear-card--wide">
            <div class="gear-img-wrap">
              <img src={item.image} alt={item.name} />
            </div>
            <div class="gear-body">
              <span class="gear-cat">{item.category}</span>
              <h4 class="gear-name">{item.name}</h4>
              <p class="gear-note">{item.note}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="gear-group">
      <h3 class="group-title">Pedalboard</h3>
      <div class="gear-grid">
        {pedals.map(item => (
          <div class="gear-card">
            <div class="gear-img-wrap">
              <img src={item.image} alt={item.name} />
            </div>
            <div class="gear-body">
              <span class="gear-cat">{item.category}</span>
              <h4 class="gear-name">{item.name}</h4>
              <p class="gear-note">{item.note}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  section { background: var(--bg-2); border-top: 1px solid var(--border); }

  .group-title {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .gear-group { margin-bottom: 4rem; }
  .gear-group:last-child { margin-bottom: 0; }

  .gear-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.25rem;
  }
  .gear-grid--amp {
    grid-template-columns: minmax(220px, 400px);
  }

  .gear-card {
    background: var(--bg-3);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    transition: border-color 0.2s, transform 0.2s;
  }
  .gear-card:hover {
    border-color: var(--accent-dim);
    transform: translateY(-2px);
  }
  .gear-card--wide { max-width: 400px; }

  .gear-img-wrap {
    aspect-ratio: 4/3;
    overflow: hidden;
    background: #111;
  }
  .gear-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.7;
    transition: opacity 0.3s;
  }
  .gear-card:hover .gear-img-wrap img { opacity: 0.9; }

  .gear-body { padding: 1.1rem 1.25rem 1.4rem; }

  .gear-cat {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .gear-name {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    color: var(--text);
    margin: 0.3rem 0 0.6rem;
  }

  .gear-note {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.65;
  }
</style>
